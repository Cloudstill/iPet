{
  "type": "function",
  "function": {
    "name": "web_search",
    "description": "用免 Key 的 DuckDuckGo 搜索公开网页，优先返回 Instant Answer 摘要，并合并普通网页结果的标题、链接和摘要。",
    "parameters": {
      "type": "object",
      "required": [
        "query"
      ],
      "properties": {
        "query": {
          "type": "string",
          "description": "搜索关键词。"
        },
        "maxResults": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "default": 8,
          "description": "最多返回多少条结果。"
        }
      },
      "additionalProperties": false
    }
  }
}
