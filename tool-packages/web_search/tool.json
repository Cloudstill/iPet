{
  "name": "web_search",
  "displayName": "网页搜索",
  "description": "用免 Key 的 DuckDuckGo 搜索公开网页，优先返回 Instant Answer 摘要，并合并普通网页结果的标题、链接和摘要。",
  "kind": "builtin",
  "enabled": true,
  "builtIn": true,
  "version": "1.0.0",
  "runtime": {
    "type": "rust-builtin",
    "dispatcher": "ToolDispatcher::dispatch_builtin",
    "source": "tool-packages/desktop_tools/rust"
  },
  "parameters": {
    "type": "object",
    "required": ["query"],
    "properties": {
      "query": {
        "type": "string",
        "description": "搜索关键词。"
      },
      "maxResults": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20,
        "default": 8,
        "description": "最多返回多少条结果。"
      }
    },
    "additionalProperties": false
  },
  "permissions": ["network"],
  "safety": {
    "readOnly": true,
    "notes": "向 DuckDuckGo Instant Answer API 与 HTML 搜索结果页发起 HTTPS GET，带超时与响应大小上限，不发送任何 Key。"
  }
}
