{
  "type": "function",
  "function": {
    "name": "weather_lookup",
    "description": "查询指定城市的当前天气和可选短期预报（温度、体感、湿度、风速、天气描述、降雨概率），使用免 Key 的 wttr.in 服务。",
    "parameters": {
      "type": "object",
      "required": [
        "city"
      ],
      "properties": {
        "city": {
          "type": "string",
          "description": "城市名称，例如 Tokyo、北京。"
        },
        "units": {
          "type": "string",
          "enum": [
            "c",
            "f"
          ],
          "default": "c",
          "description": "温度单位：c 摄氏、f 华氏。"
        },
        "includeForecast": {
          "type": "boolean",
          "default": true,
          "description": "是否返回短期预报。"
        },
        "forecastDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "default": 3,
          "description": "返回几天预报，最多 5 天。"
        }
      },
      "additionalProperties": false
    }
  }
}
